{
  "name": "openpgx",
  "version": "0.3.0",
  "description": "Open standard for pharmacogenomic data. Upload your DNA, ask about medications.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openpgx": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "node dist/server-http.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/server-http.ts",
    "build": "tsc",
    "rebuild-embeddings": "npm run build && node scripts/rebuild-embeddings.mjs",
    "clean": "rm -rf dist",
    "check-dna": "bash scripts/check-no-dna.sh",
    "precommit": "npm run check-dna",
    "prepare": "if [ -d .git ]; then cp scripts/check-no-dna.sh .git/hooks/pre-commit 2>/dev/null && chmod +x .git/hooks/pre-commit 2>/dev/null; fi || true",
    "prepublishOnly": "npm run check-dna && npm run build"
  },
  "keywords": [
    "mcp",
    "pharmacogenomics",
    "pgx",
    "dna",
    "23andme",
    "genetics",
    "medications",
    "claude",
    "anthropic",
    "open-standard"
  ],
  "author": "OpenPGx <press@openpgx.ai>",
  "license": "MIT",
  "homepage": "https://openpgx.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-pgx/open-pgx.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "data"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "openai": "^6.34.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
