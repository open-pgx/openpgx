# OpenPGx Environment Variables
# Copy to .env and fill in values

# Required: OpenAI API key for drug semantic search (text-embedding-3-small)
# Used at runtime for query embedding and by rebuild-embeddings for drug vectors
OPENAI_API_KEY=sk-...

# Optional: PharmGKB API key for direct database queries
# PHARMGKB_API_KEY=

# Optional: DrugBank API key for drug interaction data
# DRUGBANK_API_KEY=
